# ── OpenAI ──────────────────────────────────────────────
OPENAI_API_KEY=your_key_here

# ── Redis ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── AgentShield Core ────────────────────────────────────
AGENTSHIELD_LOG_LEVEL=INFO
AGENTSHIELD_POLICY_PATH=./policy.yaml
AGENTSHIELD_BLOCKING_ENABLED=true
AGENTSHIELD_DETECTION_ENABLED=true

# ── Detection Thresholds ───────────────────────────────
AGENTSHIELD_GOAL_DRIFT_THRESHOLD=0.35
AGENTSHIELD_GOAL_DRIFT_BLOCK_THRESHOLD=0.55
AGENTSHIELD_MEMORY_POISON_ZSCORE_THRESHOLD=2.5
AGENTSHIELD_INJECTION_SIMILARITY_THRESHOLD=0.80

# ── Backend ─────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173
