# ═══════════════════════════════════════════════
# AgentShield — Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ═══════════════════════════════════════════════

# ── LLM Provider Keys ──────────────────────────
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# ── Redis ──────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── AgentShield Core ───────────────────────────
AGENTSHIELD_LOG_LEVEL=INFO
AGENTSHIELD_BLOCKING_ENABLED=true
AGENTSHIELD_DETECTION_ENABLED=true
AGENTSHIELD_AUDIT_LOG_PATH=./logs/audit.jsonl

# ── Detection Thresholds ───────────────────────
AGENTSHIELD_GOAL_DRIFT_THRESHOLD=0.35
AGENTSHIELD_GOAL_DRIFT_BLOCK_THRESHOLD=0.55
AGENTSHIELD_MEMORY_POISON_ZSCORE_THRESHOLD=2.5
AGENTSHIELD_INJECTION_SIMILARITY_THRESHOLD=0.80
AGENTSHIELD_INJECTION_PATTERN_THRESHOLD=0.25
AGENTSHIELD_ANOMALY_SENSITIVITY=0.85

# ── DNA Fingerprinting ─────────────────────────
AGENTSHIELD_DNA_MIN_SESSIONS=10
AGENTSHIELD_DNA_LEARNING_RATE=0.1

# ── Canary ─────────────────────────────────────
AGENTSHIELD_CANARY_ENABLED=true
AGENTSHIELD_CANARY_ROTATION_SESSIONS=50

# ── Embeddings ─────────────────────────────────
AGENTSHIELD_EMBEDDING_MODEL=all-MiniLM-L6-v2
AGENTSHIELD_EMBEDDING_DEVICE=auto

# ── Backend ────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173

# ── Integrations (Phase 11) ────────────────────
SLACK_WEBHOOK_URL=
PAGERDUTY_ROUTING_KEY=
OTEL_EXPORTER_OTLP_ENDPOINT=

# ── Threat Intelligence Network (Phase 12) ─────
AGENTSHIELD_THREAT_INTEL_ENABLED=false
AGENTSHIELD_THREAT_INTEL_ENDPOINT=https://intel.agentshield.dev